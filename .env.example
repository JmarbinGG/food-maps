# ============================================================================
# FoodMaps environment template — copy to .env and fill in real values.
# DO NOT commit .env (it is in .gitignore).
# ============================================================================

# ---- Database (MySQL on AWS RDS) ----
DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/DBNAME

# ---- App / auth ----
JWT_SECRET=change-me-to-a-long-random-string
DEBUG_MODE=false

# ---- Mapbox (maps + geocoding) ----
MAPBOX_TOKEN=pk.your_mapbox_public_token

# ---- Twilio (SMS) ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_KEY=optional_legacy_key
TWILIO_PHONE_NUMBER="+15555555555"
TWILIO_API_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_twilio_api_secret

# ---- OpenAI (AI assistant) ----
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_KEY

# ---- AI configuration ----
AI_CHAT_MODEL=gpt-4o-mini
REMINDER_CHECK_INTERVAL=900
